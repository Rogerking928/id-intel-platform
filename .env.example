# Copy this file to ".env" and fill in what you have. Everything is OPTIONAL —
# the platform runs fully without any of these (rule-based extraction offline).
#
# Load it before running, e.g. on WSL/Linux:   set -a; source .env; set +a
# or on Windows PowerShell, set them as environment variables.

# --- AI (optional, free tier) -------------------------------------------------
# Get a free key at https://aistudio.google.com/apikey  (no credit card).
# When set, Gemini extraction + AI trend narrative turn on automatically.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- PubMed (optional) --------------------------------------------------------
# A free NCBI key raises the rate limit; not required for the MVP.
NCBI_API_KEY=
CONTACT_EMAIL=wangyenjen0301@gmail.com

# --- Volume knobs (optional) --------------------------------------------------
PUBMED_MAX_PER_QUERY=40
PUBMED_LOOKBACK_DAYS=30
CT_MAX_STUDIES=40
WHO_MAX_ITEMS=30
